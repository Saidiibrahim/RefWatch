/* Copy to Secrets.xcconfig (DO NOT COMMIT) */
// OpenAI credentials are server-side only for the assistant proxy.
// Do not add a local OpenAI key here.

// Supabase publishable key and project URL for local development/testing.
// Compose URL without typing '//' to avoid .xcconfig comment parsing
SCHEME = https
HOST = your-supabase-host
SLASH = /
SUPABASE_URL = $(SCHEME):$(SLASH)$(SLASH)$(HOST)

// Prefer publishable key naming; keep ANON as an alias for compatibility
SUPABASE_PUBLISHABLE_KEY = your-supabase-publishable-key
SUPABASE_ANON_KEY = $(SUPABASE_PUBLISHABLE_KEY)

// Google Sign-In OAuth Client ID
// Create at: https://console.cloud.google.com/apis/credentials
GID_CLIENT_ID = your-google-oauth-client-id

// Reversed Client ID (for URL scheme callback)
// Format: com.googleusercontent.apps.YOUR_CLIENT_ID
GID_REVERSED_CLIENT_ID = com.googleusercontent.apps.your-client-id
